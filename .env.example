# DernekPro Environment Variables
# Copy this file to .env.local and fill in the values

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=DernekPro

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dernekpro

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=change-this-to-a-random-secret-key
JWT_REFRESH_SECRET=change-this-to-another-random-secret

# iyzico Payment
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# SendGrid Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@dernekpro.com

# Netgsm SMS
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_HEADER=

# Google
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=dernekpro
R2_PUBLIC_URL=
