generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== TENANT (SaaS Multi-Tenant) =====
model Tenant {
  id           String   @id @default(cuid())
  subdomain    String   @unique
  customDomain String?  @unique @map("custom_domain")
  name         String
  shortName    String?  @map("short_name")
  logo         String?
  favicon      String?
  plan         Plan     @default(STARTER)
  settings     Json     @default("{}")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  users        User[]
  members      Member[]
  posts        Post[]
  categories   Category[]
  events       Event[]
  galleryAlbums GalleryAlbum[]
  campaigns    Campaign[]
  donations    Donation[]
  dues         Due[]
  transactions Transaction[]
  pages        Page[]
  slides       Slide[]
  membershipTypes MembershipType[]
  contacts     Contact[]
  liveStreams  LiveStream[]
  notifications Notification[]
  emailTemplates EmailTemplate[]
  tenantModules  TenantModule[]
  branches       Branch[]
  media          Media[]
  sponsorChildren SponsorChild[]
  bankAccounts   BankAccount[]

  @@map("tenants")
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ===== KULLANICI (Admin/Panel Users) =====
model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  role         UserRole  @default(MEMBER)
  avatar       String?
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts        Post[]    @relation("PostAuthor")
  sessions     Session[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  FINANCIAL
  MODERATOR
  MEMBER
}

// ===== OTURUM (Sessions) =====
model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  token        String   @unique
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ===== UYE (Members) =====
model Member {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  email        String
  passwordHash String?      @map("password_hash")
  fullName     String       @map("full_name")
  phone        String?
  tcNo         String?      @map("tc_no") // Encrypted
  birthDate    DateTime?    @map("birth_date")
  gender       Gender?
  address      String?
  city         String?
  occupation   String?
  education    String?
  photo        String?
  memberTypeId String?      @map("member_type_id")
  status       MemberStatus @default(PENDING)
  referenceId  String?      @map("reference_id")
  joinedAt     DateTime?    @map("joined_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberType   MembershipType? @relation(fields: [memberTypeId], references: [id])
  reference    Member?      @relation("MemberReference", fields: [referenceId], references: [id])
  referrals    Member[]     @relation("MemberReference")
  dues         Due[]
  donations    Donation[]
  eventRegistrations EventRegistration[]
  notificationReads  NotificationRead[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([status])
  @@map("members")
}

enum Gender {
  MALE
  FEMALE
}

enum MemberStatus {
  PENDING
  ACTIVE
  PASSIVE
  SUSPENDED
  REJECTED
}

// ===== UYELIK TURLERI =====
model MembershipType {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  name       String
  annualFee  Float   @default(0) @map("annual_fee")
  benefits   String?
  order      Int     @default(0)
  isActive   Boolean @default(true) @map("is_active")

  // Relations
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members    Member[]

  @@index([tenantId])
  @@map("membership_types")
}

// ===== ICERIK (Posts: Haberler, Faaliyetler, Duyurular) =====
model Post {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  type         PostType
  title        String
  slug         String
  excerpt      String?
  content      String
  coverImage   String?    @map("cover_image")
  coverImageAlt String?   @map("cover_image_alt")
  categoryId   String?    @map("category_id")
  tags         String[]   @default([])
  authorId     String?    @map("author_id")
  status       PostStatus @default(DRAFT)
  isFeatured   Boolean    @default(false) @map("is_featured")
  publishedAt  DateTime?  @map("published_at")
  metaTitle    String?    @map("meta_title")
  metaDesc     String?    @map("meta_desc")
  canonicalUrl String?    @map("canonical_url")
  ogImage      String?    @map("og_image")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     Category?  @relation(fields: [categoryId], references: [id])
  author       User?      @relation("PostAuthor", fields: [authorId], references: [id])

  @@unique([tenantId, slug, type])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([publishedAt])
  @@map("posts")
}

enum PostType {
  NEWS
  ACTIVITY
  ANNOUNCEMENT
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ===== KATEGORI =====
model Category {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String
  description String?
  parentId    String?  @map("parent_id")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  posts       Post[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

// ===== ETKINLIK =====
model Event {
  id                  String      @id @default(cuid())
  tenantId            String      @map("tenant_id")
  title               String
  slug                String
  description         String
  coverImage          String?     @map("cover_image")
  startAt             DateTime    @map("start_at")
  endAt               DateTime    @map("end_at")
  location            String?
  latitude            Float?
  longitude           Float?
  eventType           EventType   @default(IN_PERSON) @map("event_type")
  capacity            Int?
  isFree              Boolean     @default(true) @map("is_free")
  price               Float?
  requiresRegistration Boolean    @default(false) @map("requires_registration")
  status              EventStatus @default(UPCOMING)
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relations
  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registrations       EventRegistration[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([startAt])
  @@map("events")
}

enum EventType {
  ONLINE
  IN_PERSON
  HYBRID
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  memberId  String   @map("member_id")
  createdAt DateTime @default(now()) @map("created_at")

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@map("event_registrations")
}

// ===== GALERI =====
model GalleryAlbum {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  title       String
  slug        String
  coverImage  String?        @map("cover_image")
  category    String?        @default("genel")
  description String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  images     GalleryImage[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("gallery_albums")
}

model GalleryImage {
  id           String       @id @default(cuid())
  albumId      String       @map("album_id")
  url          String
  thumbnailUrl String?      @map("thumbnail_url")
  alt          String       @default("")
  order        Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  album        GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
  @@map("gallery_images")
}

// ===== KAMPANYA & BAGIS =====
model Campaign {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  title           String
  slug            String
  description     String
  coverImage      String?   @map("cover_image")
  targetAmount    Float     @map("target_amount")
  collectedAmount Float     @default(0) @map("collected_amount")
  deadline        DateTime?
  isActive        Boolean        @default(true) @map("is_active")
  status          CampaignStatus @default(ACTIVE)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  donations       Donation[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("campaigns")
}

enum CampaignStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model Donation {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  campaignId    String?       @map("campaign_id")
  memberId      String?       @map("member_id")
  donorName     String        @map("donor_name")
  donorEmail    String?       @map("donor_email")
  donorPhone    String?       @map("donor_phone")
  amount        Float
  donationType  DonationType  @default(GENERAL) @map("donation_type")
  paymentMethod PaymentMethod @default(CREDIT_CARD) @map("payment_method")
  isAnonymous   Boolean       @default(false) @map("is_anonymous")
  isRecurring   Boolean       @default(false) @map("is_recurring")
  status        DonationStatus @default(PENDING)
  transactionId String?       @map("transaction_id")
  receiptUrl    String?       @map("receipt_url")
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign      Campaign? @relation(fields: [campaignId], references: [id])
  member        Member?   @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([campaignId])
  @@index([createdAt])
  @@map("donations")
}

enum DonationType {
  GENERAL
  ZEKAT
  FITRE
  SADAKA
  KURBAN
  ADAK
  AKIKA
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CASH
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ===== AIDAT =====
model Due {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  memberId  String    @map("member_id")
  period    String    // e.g. "2026-01"
  amount    Float
  paidAt    DateTime? @map("paid_at")
  status    DueStatus @default(PENDING)
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, memberId, period])
  @@index([tenantId])
  @@index([memberId])
  @@map("dues")
}

enum DueStatus {
  PENDING
  PAID
  OVERDUE
}

// ===== MUHASEBE =====
model Transaction {
  id          String          @id @default(cuid())
  tenantId    String          @map("tenant_id")
  type        TransactionType
  amount      Float
  category    String
  description String
  date        DateTime
  receiptUrl  String?         @map("receipt_url")
  createdAt   DateTime        @default(now()) @map("created_at")

  // Relations
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([date])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ===== CMS SAYFALAR =====
model Page {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  title       String
  slug        String
  content     String
  template    String?
  metaTitle   String?  @map("meta_title")
  metaDesc    String?  @map("meta_desc")
  isPublished Boolean  @default(false) @map("is_published")
  showInMenu  Boolean  @default(false) @map("show_in_menu")
  order       Int      @default(0)
  sections    Json?    // Page builder section config JSON
  customCss   String?  @map("custom_css")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("pages")
}

// ===== SLIDER =====
model Slide {
  id             String  @id @default(cuid())
  tenantId       String  @map("tenant_id")
  type           String  @default("image") // image | video
  mediaUrl       String  @map("media_url")
  mobileMediaUrl String? @map("mobile_media_url")
  title          String?
  subtitle       String?
  buttonText     String? @map("button_text")
  buttonLink     String? @map("button_link")
  order          Int     @default(0)
  isActive       Boolean @default(true) @map("is_active")
  badge          String?
  bgColor        String? @map("bg_color")
  accentColor    String? @map("accent_color")
  statsLabel     String? @map("stats_label")
  statsValue     String? @map("stats_value")
  slideDate      String? @map("slide_date")
  location       String?

  // Relations
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("slides")
}

// ===== ILETISIM FORMU =====
model Contact {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isRead])
  @@map("contacts")
}

// ===== CANLI YAYIN =====
model LiveStream {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  title        String
  description  String?
  youtubeUrl   String           @map("youtube_url")
  thumbnailUrl String?          @map("thumbnail_url")
  scheduledAt  DateTime         @map("scheduled_at")
  startedAt    DateTime?        @map("started_at")
  endedAt      DateTime?        @map("ended_at")
  status       LiveStreamStatus @default(SCHEDULED)
  notifyUsers  Boolean          @default(false) @map("notify_users")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([scheduledAt])
  @@map("live_streams")
}

enum LiveStreamStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

// ===== BILDIRIMLER =====
model Notification {
  id              String             @id @default(cuid())
  tenantId        String             @map("tenant_id")
  title           String
  message         String
  type            NotificationType   @default(GENERAL)
  link            String?
  isGlobal        Boolean            @default(true) @map("is_global")
  sendEmail       Boolean            @default(false) @map("send_email")
  emailTemplateId String?            @map("email_template_id")
  sentAt          DateTime?          @map("sent_at")
  createdAt       DateTime           @default(now()) @map("created_at")

  // Relations
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  emailTemplate   EmailTemplate?     @relation(fields: [emailTemplateId], references: [id])
  reads           NotificationRead[]

  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  GENERAL
  LIVE_STREAM
  EVENT
  ANNOUNCEMENT
  CAMPAIGN
  SYSTEM
}

model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String       @map("notification_id")
  memberId       String       @map("member_id")
  readAt         DateTime     @default(now()) @map("read_at")

  // Relations
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([notificationId, memberId])
  @@index([memberId])
  @@map("notification_reads")
}

// ===== E-POSTA SABLONLARI =====
model EmailTemplate {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  subject     String
  htmlContent String   @map("html_content")
  variables   String[] @default([])
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("email_templates")
}

// ===== MODUL YONETIMI =====
model TenantModule {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  moduleCode  String    @map("module_code")
  isActive    Boolean   @default(false) @map("is_active")
  settings    Json      @default("{}")
  activatedAt DateTime? @map("activated_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleCode])
  @@index([tenantId])
  @@map("tenant_modules")
}

// ===== SUBE YONETIMI =====
enum BranchType {
  MERKEZ
  SUBE
  TEMSILCILIK
  IRTIBAT_BUROSU
}

enum BranchStatus {
  ACTIVE
  PASSIVE
  CLOSED
}

model Branch {
  id              String       @id @default(cuid())
  tenantId        String       @map("tenant_id")
  name            String
  slug            String
  code            String?
  type            BranchType   @default(SUBE)
  status          BranchStatus @default(ACTIVE)

  // Iletisim
  phone           String?
  email           String?
  fax             String?

  // Adres
  address         String?
  city            String?
  district        String?
  postalCode      String?      @map("postal_code")
  latitude        Float?
  longitude       Float?

  // Baskan
  presidentName   String?      @map("president_name")
  presidentPhone  String?      @map("president_phone")
  presidentEmail  String?      @map("president_email")
  presidentPhoto  String?      @map("president_photo")

  // Detay
  workingHours    Json?        @map("working_hours")
  socialMedia     Json?        @map("social_media")
  gallery         String[]     @default([])
  description     String?
  foundedAt       DateTime?    @map("founded_at")
  memberCount     Int          @default(0) @map("member_count")
  order           Int          @default(0)

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages        BranchMessage[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("branches")
}

model BranchMessage {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([branchId])
  @@index([isRead])
  @@map("branch_messages")
}

// ===== MEDYA DOSYALARI =====
model Media {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  url          String
  alt          String   @default("")
  folder       String   @default("general")
  uploadedBy   String?  @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, folder])
  @@map("media")
}

// ===== COCUK SPONSORLUK =====
model SponsorChild {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  age         Int
  gender      String   @default("male")
  country     String   @default("Türkiye")
  city        String?
  story       String   @db.Text
  photoUrl    String   @map("photo_url")
  goalAmount  Float    @map("goal_amount")
  collected   Float    @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  isFeatured  Boolean  @default(false) @map("is_featured")
  category    String   @default("giydirme")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("sponsor_children")
}

// ===== BANKA HESAPLARI =====
model BankAccount {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  bankName    String   @map("bank_name")
  bankLogo    String?  @map("bank_logo")
  accountName String   @map("account_name")
  iban        String
  accountNo   String?  @map("account_no")
  branchName  String?  @map("branch_name")
  branchCode  String?  @map("branch_code")
  currency    String   @default("TRY")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("bank_accounts")
}
