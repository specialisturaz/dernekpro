generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== TENANT (SaaS Multi-Tenant) =====
model Tenant {
  id           String   @id @default(cuid())
  subdomain    String   @unique
  customDomain String?  @unique @map("custom_domain")
  name         String
  shortName    String?  @map("short_name")
  logo         String?
  favicon      String?
  plan         Plan     @default(STARTER)
  settings     Json     @default("{}")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  users        User[]
  members      Member[]
  posts        Post[]
  categories   Category[]
  events       Event[]
  galleryAlbums GalleryAlbum[]
  campaigns    Campaign[]
  donations    Donation[]
  dues         Due[]
  transactions Transaction[]
  pages        Page[]
  slides       Slide[]
  membershipTypes MembershipType[]
  contacts     Contact[]

  @@map("tenants")
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ===== KULLANICI (Admin/Panel Users) =====
model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  role         UserRole  @default(MEMBER)
  avatar       String?
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts        Post[]    @relation("PostAuthor")
  sessions     Session[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  FINANCIAL
  MODERATOR
  MEMBER
}

// ===== OTURUM (Sessions) =====
model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  token        String   @unique
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ===== UYE (Members) =====
model Member {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  email        String
  passwordHash String?      @map("password_hash")
  fullName     String       @map("full_name")
  phone        String?
  tcNo         String?      @map("tc_no") // Encrypted
  birthDate    DateTime?    @map("birth_date")
  gender       Gender?
  address      String?
  city         String?
  occupation   String?
  education    String?
  photo        String?
  memberTypeId String?      @map("member_type_id")
  status       MemberStatus @default(PENDING)
  referenceId  String?      @map("reference_id")
  joinedAt     DateTime?    @map("joined_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberType   MembershipType? @relation(fields: [memberTypeId], references: [id])
  reference    Member?      @relation("MemberReference", fields: [referenceId], references: [id])
  referrals    Member[]     @relation("MemberReference")
  dues         Due[]
  donations    Donation[]
  eventRegistrations EventRegistration[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([status])
  @@map("members")
}

enum Gender {
  MALE
  FEMALE
}

enum MemberStatus {
  PENDING
  ACTIVE
  PASSIVE
  SUSPENDED
  REJECTED
}

// ===== UYELIK TURLERI =====
model MembershipType {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  name       String
  annualFee  Float   @default(0) @map("annual_fee")
  benefits   String?
  order      Int     @default(0)
  isActive   Boolean @default(true) @map("is_active")

  // Relations
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members    Member[]

  @@index([tenantId])
  @@map("membership_types")
}

// ===== ICERIK (Posts: Haberler, Faaliyetler, Duyurular) =====
model Post {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  type         PostType
  title        String
  slug         String
  excerpt      String?
  content      String
  coverImage   String?    @map("cover_image")
  coverImageAlt String?   @map("cover_image_alt")
  categoryId   String?    @map("category_id")
  tags         String[]   @default([])
  authorId     String?    @map("author_id")
  status       PostStatus @default(DRAFT)
  isFeatured   Boolean    @default(false) @map("is_featured")
  publishedAt  DateTime?  @map("published_at")
  metaTitle    String?    @map("meta_title")
  metaDesc     String?    @map("meta_desc")
  canonicalUrl String?    @map("canonical_url")
  ogImage      String?    @map("og_image")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     Category?  @relation(fields: [categoryId], references: [id])
  author       User?      @relation("PostAuthor", fields: [authorId], references: [id])

  @@unique([tenantId, slug, type])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([publishedAt])
  @@map("posts")
}

enum PostType {
  NEWS
  ACTIVITY
  ANNOUNCEMENT
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ===== KATEGORI =====
model Category {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String
  description String?
  parentId    String?  @map("parent_id")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  posts       Post[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

// ===== ETKINLIK =====
model Event {
  id                  String      @id @default(cuid())
  tenantId            String      @map("tenant_id")
  title               String
  slug                String
  description         String
  coverImage          String?     @map("cover_image")
  startAt             DateTime    @map("start_at")
  endAt               DateTime    @map("end_at")
  location            String?
  latitude            Float?
  longitude           Float?
  eventType           EventType   @default(IN_PERSON) @map("event_type")
  capacity            Int?
  isFree              Boolean     @default(true) @map("is_free")
  price               Float?
  requiresRegistration Boolean    @default(false) @map("requires_registration")
  status              EventStatus @default(UPCOMING)
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relations
  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registrations       EventRegistration[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([startAt])
  @@map("events")
}

enum EventType {
  ONLINE
  IN_PERSON
  HYBRID
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  memberId  String   @map("member_id")
  createdAt DateTime @default(now()) @map("created_at")

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@map("event_registrations")
}

// ===== GALERI =====
model GalleryAlbum {
  id         String         @id @default(cuid())
  tenantId   String         @map("tenant_id")
  title      String
  slug       String
  coverImage String?        @map("cover_image")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  images     GalleryImage[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("gallery_albums")
}

model GalleryImage {
  id           String       @id @default(cuid())
  albumId      String       @map("album_id")
  url          String
  thumbnailUrl String?      @map("thumbnail_url")
  alt          String       @default("")
  order        Int          @default(0)
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  album        GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
  @@map("gallery_images")
}

// ===== KAMPANYA & BAGIS =====
model Campaign {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  title           String
  slug            String
  description     String
  coverImage      String?   @map("cover_image")
  targetAmount    Float     @map("target_amount")
  collectedAmount Float     @default(0) @map("collected_amount")
  deadline        DateTime?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  donations       Donation[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("campaigns")
}

model Donation {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  campaignId    String?       @map("campaign_id")
  memberId      String?       @map("member_id")
  donorName     String        @map("donor_name")
  donorEmail    String?       @map("donor_email")
  donorPhone    String?       @map("donor_phone")
  amount        Float
  donationType  DonationType  @default(GENERAL) @map("donation_type")
  paymentMethod PaymentMethod @default(CREDIT_CARD) @map("payment_method")
  isAnonymous   Boolean       @default(false) @map("is_anonymous")
  isRecurring   Boolean       @default(false) @map("is_recurring")
  status        DonationStatus @default(PENDING)
  transactionId String?       @map("transaction_id")
  receiptUrl    String?       @map("receipt_url")
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign      Campaign? @relation(fields: [campaignId], references: [id])
  member        Member?   @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([campaignId])
  @@index([createdAt])
  @@map("donations")
}

enum DonationType {
  GENERAL
  ZEKAT
  FITRE
  SADAKA
  KURBAN
  ADAK
  AKIKA
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CASH
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ===== AIDAT =====
model Due {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  memberId  String    @map("member_id")
  period    String    // e.g. "2026-01"
  amount    Float
  paidAt    DateTime? @map("paid_at")
  status    DueStatus @default(PENDING)
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, memberId, period])
  @@index([tenantId])
  @@index([memberId])
  @@map("dues")
}

enum DueStatus {
  PENDING
  PAID
  OVERDUE
}

// ===== MUHASEBE =====
model Transaction {
  id          String          @id @default(cuid())
  tenantId    String          @map("tenant_id")
  type        TransactionType
  amount      Float
  category    String
  description String
  date        DateTime
  receiptUrl  String?         @map("receipt_url")
  createdAt   DateTime        @default(now()) @map("created_at")

  // Relations
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([date])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ===== CMS SAYFALAR =====
model Page {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  title       String
  slug        String
  content     String
  template    String?
  metaTitle   String?  @map("meta_title")
  metaDesc    String?  @map("meta_desc")
  isPublished Boolean  @default(false) @map("is_published")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("pages")
}

// ===== SLIDER =====
model Slide {
  id             String  @id @default(cuid())
  tenantId       String  @map("tenant_id")
  type           String  @default("image") // image | video
  mediaUrl       String  @map("media_url")
  mobileMediaUrl String? @map("mobile_media_url")
  title          String?
  subtitle       String?
  buttonText     String? @map("button_text")
  buttonLink     String? @map("button_link")
  order          Int     @default(0)
  isActive       Boolean @default(true) @map("is_active")

  // Relations
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("slides")
}

// ===== ILETISIM FORMU =====
model Contact {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isRead])
  @@map("contacts")
}
